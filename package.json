{
  "name": "build-buddy",
  "private": true,
  "version": "0.0.1",
  "description": "Build Buddy — Residential Design & Cost-Estimation Platform",
  "packageManager": "pnpm@9.15.5",
  "engines": {
    "node": ">=20.19.4",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "assets:ingest": "tsx scripts/assets-ingest.ts",
    "tokens:sync": "tsx scripts/tokens-sync.ts",
    "brand:generate": "tsx scripts/generate-brand-assets.ts",
    "mock-api:dev": "pnpm -C services/mock-api run dev",
    "start": "pnpm -C apps/mobile run start",
    "android": "pnpm -C apps/mobile run android",
    "ios": "pnpm -C apps/mobile run ios",
    "web": "pnpm -C apps/mobile run web",
    "dev": "concurrently \"pnpm mock-api:dev\" \"pnpm android\"",
    "storybook": "pnpm -C apps/mobile run storybook",
    "storybook:web": "pnpm -C apps/mobile run storybook:web",
    "storybook:ios": "pnpm -C apps/mobile run storybook:ios",
    "storybook:android": "pnpm -C apps/mobile run storybook:android",
    "storybook:gen": "pnpm -C apps/mobile run storybook:gen"
  },
  "dependencies": {
    "concurrently": "^8.2.2",
    "expo": "^55.0.18"
  },
  "devDependencies": {
    "@types/react": "~19.2.10",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.2.5",
    "tsx": "^4.7.1",
    "typescript": "^5.4.5"
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.0",
      "react-native": "0.83.6",
      "react-native-worklets": "0.7.4",
      "valibot": "1.3.1"
    }
  }
}
