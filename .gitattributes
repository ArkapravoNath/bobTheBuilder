# Normalize line endings
* text=auto eol=lf

# LFS — binary assets
apps/mobile/assets/**/*.png filter=lfs diff=lfs merge=lfs -text
apps/mobile/assets/**/*.svg filter=lfs diff=lfs merge=lfs -text
apps/mobile/assets/**/*.jpg filter=lfs diff=lfs merge=lfs -text
apps/mobile/assets/**/*.webp filter=lfs diff=lfs merge=lfs -text
apps/mobile/assets/brand/*.svg filter=lfs diff=lfs merge=lfs -text
docs/*.docx filter=lfs diff=lfs merge=lfs -text
docs/*.xlsx filter=lfs diff=lfs merge=lfs -text
